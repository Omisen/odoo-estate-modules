<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <record id="view_res_config_settings_form" model="ir.ui.view">
        <field name="name">res.config.settings.view.inherit.estate_account.form</field>
        <field name="model">res.config.settings</field>
        <field name="inherit_id" ref="base_setup.action_general_configuration"/>
        <field name="arch" type="xml">
            <xpath expr="//div[hasclass('settings')]" position="inside">
                <div class="app_settings_block" data-string="Estate" string="Estate" data-key="estate_account">
                    <h2>Estate</h2>
                    <div class="row mt16 o_settings_container">
                        <div class="col-12 col-lg-6 o_setting_box">
                            <div class="o_setting_right_pane">
                                <label for="estate_commission_rate" string="Commission Rate"/>
                                <div class="text-muted">Percentage applied to selling price (es: 0.06 = 6%)</div>
                                <div class="content-group">
                                    <div class="mt8">
                                        <field name="estate_commission_rate" widget="percentage"/>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </xpath>
        </field>
    </record>
</odoo>