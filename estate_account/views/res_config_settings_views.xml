<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <record id="view_res_config_settings_form" model="ir.ui.view">
        <field name="name">res.config.settings.view.inherit.estate_account.form</field>
        <field name="model">res.config.settings</field>
        <field name="inherit_id" ref="base.res_config_settings_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="//form" position="inside">
                <app string="Estate" data-string="Estate" name="estate_account">
                    <!-- titolo del blocco in settings odoo -->
                    <block title="Invoicing" name="estate_invoicing_settings">
                        <setting string="Commission Rate" help="Percentage applied to selling price (es: 0.06 = 6%)">
                            <field name="estate_commission_rate"/>
                        </setting>
                    </block>
                </app>
            </xpath>
        </field>
    </record>
</odoo>