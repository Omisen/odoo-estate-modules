<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- List View -->
    <record id="view_estate_property_type_list" model="ir.ui.view">
        <field name="name">estate.property.type.list</field>
        <field name="model">estate.property.type</field>
        <field name="arch" type="xml">
            <list string="Property Types" editable="top" open_form_view="1">
                <field name="sequence" widget="handle"/>
                <field name="name" placeholder="Type: es 'Villa'"/>
                <field name="category"/>
            </list>
        </field>
    </record>

    <!-- Form View -->
    <record id="view_estate_property_type_form" model="ir.ui.view">
        <field name="name">estate.property.type.form</field>
        <field name="model">estate.property.type</field>
        <field name="arch" type="xml">
            <form string="Property Type">
                <sheet>
                    <div class="oe_button_box" name="button_box">
                        <button name="%(action_estate_property_offer)d" type="action" icon="fa-list">
                            <field name="offer_count" widget="statinfo"/>
                        </button>
                    </div>
                    <div class="oe_title">
                        <h1>
                            <field name="name"/>
                        </h1>
                    </div>
                    <group>
                        <field name="category"/>
                    </group>
                    <notebook>
                        <page string="Properties of this Type">
                            <field name="property_ids">
                                <list editable="bottom"
                                      create="False"
                                      delete="False"
                                      edit="False"
                                      decoration-success="status == 'sold'"
                                      decoration-info="status == 'offer_recieved'"
                                      decoration-warning="status == 'offer_accepted'"
                                      decoration-danger="status == 'cancelled'">
                                    <field name="name"/>
                                    <field name="postcode"/>
                                    <field name="expected_price"/>
                                    <field name="status" decoration-bf="status in ('sold', 'cancelled', 'offer_recieved', 'offer_accepted')"/>
                                </list>
                            </field>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <!-- Search View -->
    <record id="view_estate_property_type_search" model="ir.ui.view">
        <field name="name">estate.property.type.search</field>
        <field name="model">estate.property.type</field>
        <field name="arch" type="xml">
            <search string="Search Property Types">
                <field name="name"/>
                <filter string="Residential" name="filter_residential" domain="[('category', '=', 'residential')]"/>
                <filter string="Commercial"  name="filter_commercial"  domain="[('category', '=', 'commercial')]"/>
                <filter string="Land"        name="filter_land"        domain="[('category', '=', 'land')]"/>
                <filter string="Hospitality" name="filter_hospitality" domain="[('category', '=', 'hospitality')]"/>
                <group expand="0" string="Group By">
                    <filter name="group_by_category" string="Category" context="{'group_by': 'category'}"/>
                </group>
            </search>
        </field>
    </record>

    <!-- Action -->
    <record id="action_estate_property_type" model="ir.actions.act_window">
        <field name="name">Types</field>
        <field name="res_model">estate.property.type</field>
        <field name="view_mode">list,form</field>
    </record>

</odoo>
