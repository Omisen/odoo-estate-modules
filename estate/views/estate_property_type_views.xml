<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- List View -->
    <record id="view_estate_property_type_list" model="ir.ui.view">
        <field name="name">estate.property.type.list</field>
        <field name="model">estate.property.type</field>
        <field name="arch" type="xml">
            <list string="Property Types">
                <field name="sequence" widget="handle"/>
                <field name="name"/>
            </list>
        </field>
    </record>

    <!-- Form View -->
    <record id="view_estate_property_type_form" model="ir.ui.view">
        <field name="name">estate.property.type.form</field>
        <field name="model">estate.property.type</field>
        <field name="arch" type="xml">
            <form string="Property Type">
                <sheet>
                    <div class="oe_button_box" name="button_box">
                        <button name="%(action_estate_property_offer)d" type="action" icon="fa-list">
                            <field name="offer_count" widget="statinfo"/>
                        </button>
                    </div>
                    <div class="oe_title">
                        <h1>
                            <field name="name"/>
                        </h1>
                    </div>
                    <notebook>
                        <page string="Properties of this Type">
                            <field name="property_ids">
                                <list editable="bottom"
                                      create="False"
                                      delete="False"
                                      edit="False"
                                      decoration-success="status == 'sold'"
                                      decoration-info="status == 'offer_recieved'"
                                      decoration-danger="status == 'cancelled'">
                                    <field name="name"/>
                                    <field name="postcode"/>
                                    <field name="expected_price"/>
                                    <field name="status" decoration-bf="status in ('sold', 'cancelled', 'offer_recieved')"/>
                                </list>
                            </field>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <!-- Action -->
    <record id="action_estate_property_type" model="ir.actions.act_window">
        <field name="name">Types</field>
        <field name="res_model">estate.property.type</field>
        <field name="view_mode">list,form</field>
    </record>

</odoo>
