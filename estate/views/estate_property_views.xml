<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- List View -->
    <record id="view_estate_property_list" model="ir.ui.view">
        <field name="name">estate.property.list</field>
        <field name="model">estate.property</field>
        <field name="arch" type="xml">
            <list string="Properties">
                <field name="status" widget="badge"
                       decoration-info="status == 'offer_recieved'"
                       decoration-success="status == 'sold'"
                       decoration-danger="status == 'cancelled'"/>
                <field name="name"/>
                <field name="property_type_id"/>
                <field name="postcode"/>
                <field name="expected_price"/>
                <field name="date_availability"/>
            </list>
        </field>
    </record>

    <!-- Form View -->
    <record id="view_estate_property_form" model="ir.ui.view">
        <field name="name">estate.property.form</field>
        <field name="model">estate.property</field>
        <field name="arch" type="xml">
            <form string="Property">
                <header>
                    <button name="set_status_to_sold" type="object" string="Sold"/>
                    <button name="set_status_to_cancel" type="object" string="Cancel"/>
                    <button name="reset_status" type="object" string="Reset Status"/>
                    <button name="%(action_report_estate_property_html)d" type="action" string="Preview Report" class="oe_highlight"/>
                    <!-- <button name="%(action_report_estate_property)d" type="action" string="Print Report" class="oe_highlight"/> -->
                    <field name="status" widget="statusbar" statusbar_visible="new,offer_recieved,sold"/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <h1>
                            <field name="name" placeholder="Estate Property Title" readonly="status == 'sold' or status == 'cancelled'"/>
                        </h1>
                        <group>
                            <field name="property_tag_id" widget="many2many_tags" options="{'color_field': 'color'}" readonly="status == 'sold' or status == 'cancelled'"/>
                        </group>
                    </div>
                    <group>
                        <group>
                            <field name="property_type_id" readonly="status == 'sold' or status == 'cancelled'"/>
                            <field name="postcode" readonly="status == 'sold' or status == 'cancelled'"/>
                            <field name="total_area"/>
                        </group>
                        <group>
                            <field name="buyer" invisible="status != 'sold'"/>
                            <field name="selling_price" invisible="status != 'sold'"/>
                            <field name="date_availability" invisible="status == 'sold'" readonly="status == 'cancelled'"/>
                            <field name="expected_price" invisible="status == 'sold'" readonly="status == 'cancelled'"/>
                            <field name="best_price" invisible="status == 'sold'"/>
                        </group>
                    </group>

                    <notebook>
                        <page string="Spaces">
                            <group>
                                <group>
                                    <field name="bedrooms" readonly="status == 'sold' or status == 'cancelled'"/>
                                    <field name="living_area" readonly="status == 'sold' or status == 'cancelled'"/>
                                </group>
                                <group>
                                    <field name="garage" readonly="status == 'sold' or status == 'cancelled'"/>
                                    <field name="description" placeholder="More information about the property..."/>
                                </group>
                            </group>
                        </page>
                        <page string="Outdoor">
                            <group>
                                <field name="garden" readonly="status == 'sold' or status == 'cancelled'"/>
                                <field name="garden_area" invisible="garden == False" readonly="status == 'sold' or status == 'cancelled'"/>
                                <field name="garden_orientation" required="garden == True" invisible="garden == False" readonly="status == 'sold' or status == 'cancelled'"/>
                            </group>
                        </page>
                        <page string="Offers">
                            <field name="offer_ids" context="{'default_property_id': id}" readonly="status in ('sold', 'cancelled')">
                                <list editable="bottom"
                                      decoration-muted="status == 'new'"
                                      decoration-success="status == 'accept'"
                                      decoration-bf="status == 'accept'"
                                      decoration-danger="status == 'refuse'">
                                    <field name="partner_id"/>
                                    <field name="price"/>
                                    <button name="set_offer_to_accept" type="object" string="Accept" icon="fa-check" invisible="parent.status != 'offer_recieved'"/>
                                    <button name="set_offer_to_refuse" type="object" string="Refuse" icon="fa-times" invisible="parent.status != 'offer_recieved'"/>
                                    <field name="status"/>
                                    <field name="validity"/>
                                    <field name="date_deadline"/>
                                </list>
                            </field>
                        </page>
                        <page string="Salesperson">
                            <group>
                                <field name="salesperson_id"
                                       readonly="status in ('sold', 'cancelled')"
                                       context="{'form_view_ref': 'base.view_users_form'}"/>
                                <!-- widget uploaded -->
                                 <field name="name" postcode="postcode" widget="estate_hello_widget" string="Widget"/>
                            </group>
                        </page>
                    </notebook>
                    
                </sheet>
            </form>
        </field>
    </record>

    <!-- Kanban View -->
    <record id="view_estate_property_kanban" model="ir.ui.view">
        <field name="name">estate.property.kanban</field>
        <field name="model">estate.property</field>
        <field name="arch" type="xml">
            <kanban default_group_by="property_type_id" records_draggable="False" groups_draggable="false">
                <field name="offer_ids"/>
                <templates>
                    <t t-name="card">
                        <div class="mb-3 p-2">
                            <field name="status" widget="badge"
                                decoration-info="status == 'new'"
                                decoration-warning="status == 'offer_recieved'"
                                decoration-success="status == 'sold'"
                                decoration-danger="status == 'cancelled'"
                            />
                            <div class="mt-2">
                                <field name="name" class="fw-bold fs-2"/>
                            </div>
                            <br/>
                            <div class="my-2">
                                <strong>Expected Price:</strong> <field name="expected_price"/>
                                <div t-if="record.offer_ids.raw_value.length and record.status.raw_value == 'offer_recieved'">
                                    <strong>Best Price:</strong> <field name="best_price"/>
                                </div>
                                <div t-if="record.status.raw_value == 'sold'">
                                    <strong>Selling Price:</strong> <field name="selling_price"/>
                                </div>
                            </div>
                            <footer >
                                <field name="property_tag_id" widget="many2many_tags" options="{'color_field': 'color'}"/>
                            </footer>
                        </div>
                    </t>
                </templates>
            </kanban>
        </field>
    </record>


    <!-- Search View -->
    <record id="view_estate_property_search" model="ir.ui.view">
        <field name="name">estate.property.search</field>
        <field name="model">estate.property</field>
        <field name="arch" type="xml">
            <search string="Search Properties">
                <field name="name"/>
                <field name="postcode"/>
                <filter string="Available"
                        name="filter_available"
                        domain="[('date_availability', '!=', False)]"/>
                <filter string="Has Garden"
                        name="filter_has_garden"
                        domain="[('garden', '=', True)]"/>
                <field string="Area Equal"
                       name="living_area"
                       filter_domain="[('living_area', '=', self)]"/>
                <field string="Area Greater Than"
                       name="living_area"
                       filter_domain="[('living_area', '>=', self)]"/>
                <group expand="0" string="Group By">
                    <filter name="group_by_postcode"
                            string="Postcode"
                            context="{'group_by': 'postcode'}"/>
                </group>
            </search>
        </field>
    </record>

    <!-- Action -->
    <record id="action_estate_property" model="ir.actions.act_window">
        <field name="name">Properties</field>
        <field name="res_model">estate.property</field>
        <field name="view_mode">list,form,kanban</field>
    </record>

</odoo>
