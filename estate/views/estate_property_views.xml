<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- List View -->
    <record id="view_estate_property_list" model="ir.ui.view">
        <field name="name">estate.property.list</field>
        <field name="model">estate.property</field>
        <field name="arch" type="xml">
            <list string="Properties">
                <field name="status" widget="badge"
                       decoration-info="status == 'offer_recieved'"
                       decoration-warning="status == 'offer_accepted'"
                       decoration-success="status == 'sold'"
                       decoration-danger="status == 'cancelled'"/>
                <field name="name"/>
                <field name="property_type_id"/>
                <field name="postcode"/>
                <field name="expected_price"/>
                <field name="date_availability"/>
            </list>
        </field>
    </record>

    <!-- Form View -->
    <record id="view_estate_property_form" model="ir.ui.view">
        <field name="name">estate.property.form</field>
        <field name="model">estate.property</field>
        <field name="arch" type="xml">
            <form string="Property">
                <header>
                    <button name="set_status_to_sold"
                            type="object"
                            string="Mark as Sold"
                            class="oe_highlight"
                            confirm="This will create the customer invoice and mark the property as sold. Continue?"
                            invisible="status != 'offer_accepted'"/>
                    <button name="set_status_to_cancel"
                            type="object"
                            string="Cancel"
                            confirm="Are you sure you want to cancel this property?"
                            invisible="status in ('sold', 'cancelled')"/>
                    <button name="reopen_offers"
                            type="object"
                            string="Reopen Offers"
                            confirm="This will reopen the negotiation and let you choose a different offer. Continue?"
                            invisible="status not in ('offer_accepted', 'cancelled') or offer_count == 0"/>
                    
                    <!-- testig button for debug mode -->
                    <button name="action_reset_to_offer_received"
                            type="object"
                            string="Reset"
                            class="btn-warning"
                            groups="base.group_no_one"
                            confirm="Testing only: reset the property to Offer Received and all related offers to New?"
                            invisible="status not in ('sold', 'cancelled')"/>
                    
                    <button name="%(action_report_estate_property_html)d"
                            type="action"
                            class="oe_highlight"
                            string="Preview Report"
                            invisible="status != 'sold'"/>
                    <!-- <button name="%(action_report_estate_property)d"
                            type="action"
                            string="Print PDF"/> -->
                    <field  name="offer_count" 
                            widget="estate_offer_count_badge"
                            nolabel="1"
                            invisible="status == 'sold' or status == 'new'"/>
                    <field name="status" widget="estate_status_badge" nolabel="1"/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <!-- <label for="name" class="oe_edit_only"/> -->
                        <h1>
                            <field name="name"
                                   placeholder="Example: Modern apartment with terrace"
                                   readonly="status in ('offer_accepted', 'sold', 'cancelled')"/>
                        </h1>
                        <group>
                            <field name="property_tag_id"
                                   widget="many2many_tags"
                                   options="{'color_field': 'color','no_create': True, 'no_open': True}"
                                   readonly="status in ('offer_accepted', 'sold', 'cancelled')"/>
                            <field name="salesperson_id"
                                   readonly="status in ('offer_accepted', 'sold', 'cancelled')"
                                   domain="[('share', '=', False)]"
                                   options="{'no_create': True, 'no_create_edit': True}"
                                   context="{'form_view_ref': 'base.view_users_form'}"/>
                        </group>
                    </div>
                    <group string="Property Details">
                        <group>
                            <field name="property_type_id"
                                   readonly="status in ('offer_accepted', 'sold', 'cancelled')"
                                   options="{'no_create': True, 'no_open': True}"/>
                            <field name="postcode"
                                   placeholder="ZIP / Postcode"
                                   readonly="status in ('offer_accepted', 'sold', 'cancelled')"/>
                            <field name="date_availability"
                                   invisible="status == 'sold'"
                                   readonly="status in ('offer_accepted', 'cancelled')"/>
                            <field name="total_area" readonly="1"/>
                        </group>
                        <group string="Pricing">
                            <field name="expected_price"
                                   invisible="status == 'sold'"
                                   readonly="status in ('offer_accepted', 'cancelled')"/>
                            <field name="best_price" invisible="status == 'sold'" readonly="1"/>
                            <field name="selling_price" invisible="status not in ('offer_accepted', 'sold')" readonly="1"/>
                            <field name="buyer" invisible="status not in ('offer_accepted', 'sold')" readonly="1"/>
                        </group>
                    </group>

                    <notebook>
                        <page string="Indoor">
                            <group>
                                <group>
                                    <field name="bedrooms" readonly="status in ('offer_accepted', 'sold', 'cancelled')"/>
                                    <field name="living_area" readonly="status in ('offer_accepted', 'sold', 'cancelled')"/>
                                    <field name="garage" readonly="status in ('offer_accepted', 'sold', 'cancelled')"/>
                                </group>
                                <group>
                                    <field name="description" readonly="1"/>
                                </group>
                            </group>
                        </page>
                        <page string="Outdoor">
                            <group>
                                <field name="garden" readonly="status in ('offer_accepted', 'sold', 'cancelled')"/>
                                <field name="garden_area" invisible="garden == False" readonly="status in ('offer_accepted', 'sold', 'cancelled')"/>
                                <field name="garden_orientation" required="garden == True" invisible="garden == False" readonly="status in ('offer_accepted', 'sold', 'cancelled')"/>
                            </group>
                        </page>
                        <page string="Offers">
                            <field name="offer_ids" context="{'default_property_id': id}" readonly="status in ('offer_accepted', 'sold', 'cancelled')">
                                <list editable="bottom"
                                      decoration-muted="status == 'new'"
                                      decoration-success="status in ('accept','sold')"
                                      decoration-bf="status in ('accept','sold')"
                                      decoration-danger="status in ('refuse','cancelled')">
                                    <field name="partner_id"/>
                                    <field name="price"/>
                                    <field name="status"/>
                                    <button name="set_offer_to_accept" type="object" string="Accept" icon="fa-check" invisible="parent.status != 'offer_recieved' or status in ('accept', 'sold')"/>
                                    <button name="set_offer_to_refuse" type="object" string="Refuse" icon="fa-times" invisible="parent.status != 'offer_recieved' or status in ('refuse', 'sold')"/>
                                    <field name="validity"/>
                                    <field name="date_deadline"/>
                                </list>
                            </field>
                        </page>
                    </notebook>
                    
                </sheet>
            </form>
        </field>
    </record>

    <!-- Kanban View -->
    <record id="view_estate_property_kanban" model="ir.ui.view">
        <field name="name">estate.property.kanban</field>
        <field name="model">estate.property</field>
        <field name="arch" type="xml">
            <kanban default_group_by="property_type_id" records_draggable="False" groups_draggable="false">
                <field name="offer_ids"/>
                <templates>
                    <t t-name="card">
                        <div class="mb-3 p-2">
                            <field name="status" widget="badge"
                                decoration-info="status == 'new'"
                                decoration-warning="status in ('offer_recieved', 'offer_accepted')"
                                decoration-success="status == 'sold'"
                                decoration-danger="status == 'cancelled'"
                            />
                            <div class="mt-2">
                                <field name="name" class="fw-bold fs-2"/>
                            </div>
                            <br/>
                            <div class="my-2">
                                <strong>Expected Price:</strong> <field name="expected_price"/>
                                <div t-if="record.offer_ids.raw_value.length and ['offer_recieved', 'offer_accepted'].includes(record.status.raw_value)">
                                    <strong>Best Price:</strong> <field name="best_price"/>
                                </div>
                                <div t-if="['offer_accepted', 'sold'].includes(record.status.raw_value)">
                                    <strong>Selling Price:</strong> <field name="selling_price"/>
                                </div>
                            </div>
                            <footer >
                                <field name="property_tag_id" widget="many2many_tags" options="{'color_field': 'color'}"/>
                            </footer>
                        </div>
                    </t>
                </templates>
            </kanban>
        </field>
    </record>


    <!-- Search View -->
    <record id="view_estate_property_search" model="ir.ui.view">
        <field name="name">estate.property.search</field>
        <field name="model">estate.property</field>
        <field name="arch" type="xml">
            <search string="Search Properties">
                <field name="name"/>
                <field name="postcode"/>
                <field name="salesperson_id"/>
                <field name="property_type_id"/>
                <filter string="My Properties"
                        name="filter_my_properties"
                        domain="[('salesperson_id', '=', uid)]"/>
                <filter string="Available"
                        name="filter_available"
                        domain="[('date_availability', '!=', False)]"/>
                <filter string="Has Garden"
                        name="filter_has_garden"
                        domain="[('garden', '=', True)]"/>
                <filter string="Offer Accepted"
                        name="filter_offer_accepted"
                        domain="[('status', '=', 'offer_accepted')]"/>
                <filter string="Sold"
                        name="filter_sold"
                        domain="[('status', '=', 'sold')]"/>
                <field string="Area Equal"
                       name="living_area"
                       filter_domain="[('living_area', '=', self)]"/>
                <field string="Area Greater Than"
                       name="living_area"
                       filter_domain="[('living_area', '>=', self)]"/>
                <group expand="0" string="Group By">
                    <filter name="group_by_status"
                            string="Status"
                            context="{'group_by': 'status'}"/>
                    <filter name="group_by_salesperson"
                            string="Salesperson"
                            context="{'group_by': 'salesperson_id'}"/>
                    <filter name="group_by_postcode"
                            string="Postcode"
                            context="{'group_by': 'postcode'}"/>
                </group>
            </search>
        </field>
    </record>

    <!-- Action -->
    <record id="action_estate_property" model="ir.actions.act_window">
        <field name="name">Properties</field>
        <field name="res_model">estate.property</field>
        <field name="view_mode">list,form,kanban</field>
    </record>

</odoo>
