<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- Root -->
    <menuitem id="menu_estate_root" name="Real Estate" sequence="10">

        <!-- Advertisements -->
        <menuitem id="menu_advertisments" name="Advertisements">
            <menuitem id="menu_estate_property_list" action="action_estate_property"/>
        </menuitem>

        <!-- Settings -->
        <menuitem id="menu_settings" name="Settings">

            <menuitem id="menu_settings_estate" name="Estate">
                <menuitem id="menu_estate_property_type_list" action="action_estate_property_type" sequence="1"/>
                <menuitem id="menu_estate_property_tag_list" action="action_estate_property_tags" sequence="2"/>
                <menuitem id="menu_estate_property_offer_list" action="action_estate_property_offer_all" sequence="3"/>
            </menuitem>

            <menuitem id="menu_settings_odoo" name="General">
                <menuitem name="Odoo Settings" id="menu_odoo_config_settings" action="base.res_config_setting_act_window" sequence="10"/>
            </menuitem>

        </menuitem>

    </menuitem>

</odoo>
