<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <!-- #region List View -->
    <record id="view_estate_property_tags_list" model="ir.ui.view">
        <field name="name">estate.property.tag.list</field>
        <field name="model">estate.property.tag</field>
        <field name="arch" type="xml">
            <list string="Property Tags">
                <field name="name"/>
                <field name="color"/>
            </list>
        </field>
    </record>
    <!-- #endregion  -->

    <!-- #region Form -->
    <record id="view_estate_property_tags_form" model="ir.ui.view">
        <field name="name">estate.property.tag.form</field>
        <field name="model">estate.property.tag</field>
        <field name="arch" type="xml">
            <form string="Property Tag">
                <sheet>
                    <group string="Property Tag:">
                        <field name="name"/>
                        <field name="color"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>
    <!-- #endregion  -->
    
    <!-- #region Action -->
    <record id="action_estate_property_tags"  model="ir.actions.act_window">
        <field name="name">Tags</field>
        <field name="res_model">estate.property.tag</field>
        <field name="view_mode">list,form</field>
    </record>
    <!-- #endregion  -->
</odoo>
