<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <template id="website_home" name="Estate Home">
        <t t-call="website.layout">
            <div class="container py-5">
                <div class="text-center py-5">
                    <h1 class="display-4 fw-bold mb-3">Find Your Property</h1>
                    <p class="lead text-muted mb-4">Browse our latest listings and find the perfect place.</p>
                    <a href="/properties" class="btn btn-primary btn-lg">
                        <i class="fa fa-search me-2"/>Browse Properties
                    </a>
                </div>
            </div>
        </t>
    </template>

    <template id="website_property_list" name="Properties">
        <t t-call="website.layout">
            <div class="container py-5">

                <!-- Page header -->
                <div class="d-flex align-items-center justify-content-between mb-4">
                    <h1 class="mb-0">Properties</h1>
                    <span class="text-muted small"><t t-esc="len(properties)"/> listing<t t-if="len(properties) != 1">s</t></span>
                </div>

                <!-- Empty state -->
                <t t-if="not properties">
                    <div class="text-center py-5 text-muted">
                        <i class="fa fa-home fa-3x mb-3 d-block"/>
                        <p class="lead">No properties available at the moment.</p>
                    </div>
                </t>

                <!-- Responsive card grid -->
                <div class="row row-cols-1 row-cols-md-2 row-cols-xl-3 g-4">
                    <t t-foreach="properties" t-as="prop">
                        <t t-set="status_class" t-value="'bg-info' if prop.status == 'new' else 'bg-primary' if prop.status == 'offer_recieved' else 'bg-warning text-dark' if prop.status == 'offer_accepted' else 'bg-success' if prop.status == 'sold' else 'bg-danger'"/>
                        <div class="col">
                            <div class="card h-100 border-0 shadow-sm">
                                <div class="card-body d-flex flex-column">
                                    <div class="d-flex justify-content-between align-items-start mb-2">
                                        <h5 class="card-title mb-0 me-2">
                                            <a t-attf-href="/properties/#{prop.id}" class="text-decoration-none text-dark stretched-link">
                                                <span t-field="prop.name"/>
                                            </a>
                                        </h5>
                                        <span t-attf-class="badge #{status_class} text-nowrap">
                                            <span t-field="prop.status"/>
                                        </span>
                                    </div>
                                    <p class="text-muted small mb-3">
                                        <i class="fa fa-tag me-1"/>Ref: <span t-field="prop.ref"/>
                                        <t t-if="prop.postcode">
                                            &#160;&#160;<i class="fa fa-map-marker me-1"/><span t-field="prop.postcode"/>
                                        </t>
                                    </p>
                                    <div class="mt-auto pt-2 border-top">
                                        <span class="fw-bold fs-5 text-success">
                                            <span t-field="prop.expected_price" t-options='{"widget": "monetary", "display_currency": prop.env.company.currency_id}'/>
                                        </span>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </t>
                </div>

            </div>
        </t>
    </template>

    <template id="website_property_detail" name="Property Detail">
        <t t-call="website.layout">
            <div class="container py-5">

                <!-- Back button -->
                <a href="/properties" class="btn btn-outline-secondary btn-sm mb-4">
                    <i class="fa fa-arrow-left me-1"/>Back to listings
                </a>

                <!-- Hero card: title + status -->
                <t t-set="status_class" t-value="'bg-info' if property.status == 'new' else 'bg-primary' if property.status == 'offer_recieved' else 'bg-warning text-dark' if property.status == 'offer_accepted' else 'bg-success' if property.status == 'sold' else 'bg-danger'"/>
                <div class="card border-0 shadow-sm mb-4">
                    <div class="card-body d-flex justify-content-between align-items-start flex-wrap gap-2">
                        <div>
                            <h1 class="mb-1"><span t-field="property.name"/></h1>
                            <p class="text-muted mb-0 small">
                                <i class="fa fa-tag me-1"/>Ref: <span t-field="property.ref"/>
                                <t t-if="property.postcode">
                                    &#160;&#160;<i class="fa fa-map-marker me-1"/><span t-field="property.postcode"/>
                                </t>
                            </p>
                        </div>
                        <span t-attf-class="badge fs-6 #{status_class}">
                            <span t-field="property.status"/>
                        </span>
                    </div>
                </div>

                <div class="row g-4">

                    <!-- Details column -->
                    <div class="col-lg-7">
                        <div class="card border-0 shadow-sm h-100">
                            <div class="card-header bg-transparent fw-bold border-bottom">
                                <i class="fa fa-info-circle me-2 text-muted"/>Property Details
                            </div>
                            <div class="card-body">
                                <dl class="row mb-0">
                                    <dt class="col-sm-5 text-muted fw-normal">Type</dt>
                                    <dd class="col-sm-7 fw-semibold"><span t-field="property.property_type_id"/></dd>

                                    <dt class="col-sm-5 text-muted fw-normal">Available From</dt>
                                    <dd class="col-sm-7"><span t-field="property.date_availability"/></dd>

                                    <dt class="col-sm-5 text-muted fw-normal">Bedrooms</dt>
                                    <dd class="col-sm-7"><span t-field="property.bedrooms"/></dd>

                                    <dt class="col-sm-5 text-muted fw-normal">Living Area</dt>
                                    <dd class="col-sm-7"><span t-field="property.living_area"/> sqm</dd>

                                    <dt class="col-sm-5 text-muted fw-normal">Total Area</dt>
                                    <dd class="col-sm-7"><span t-field="property.total_area"/> sqm</dd>

                                    <dt class="col-sm-5 text-muted fw-normal">Garage</dt>
                                    <dd class="col-sm-7"><t t-out="'Yes' if property.garage else 'No'"/></dd>
                                </dl>
                            </div>
                        </div>
                    </div>

                    <!-- Pricing column -->
                    <div class="col-lg-5">
                        <div class="card border-0 shadow-sm h-100">
                            <div class="card-header bg-transparent fw-bold border-bottom">
                                <i class="fa fa-eur me-2 text-muted"/>Pricing
                            </div>
                            <div class="card-body d-flex flex-column gap-3">
                                <div>
                                    <p class="text-muted small mb-1">Expected Price</p>
                                    <p class="fs-3 fw-bold text-success mb-0">
                                        <span t-field="property.expected_price" t-options='{"widget": "monetary", "display_currency": property.env.company.currency_id}'/>
                                    </p>
                                </div>
                                <t t-if="property.best_price">
                                    <div class="border-top pt-3">
                                        <p class="text-muted small mb-1">Best Offer</p>
                                        <p class="fs-5 fw-semibold mb-0">
                                            <span t-field="property.best_price" t-options='{"widget": "monetary", "display_currency": property.env.company.currency_id}'/>
                                        </p>
                                    </div>
                                </t>
                                <t t-if="property.selling_price">
                                    <div class="border-top pt-3">
                                        <p class="text-muted small mb-1">Selling Price</p>
                                        <p class="fs-5 fw-semibold text-success mb-0">
                                            <span t-field="property.selling_price" t-options='{"widget": "monetary", "display_currency": property.env.company.currency_id}'/>
                                        </p>
                                    </div>
                                </t>
                            </div>
                        </div>
                    </div>

                </div>

                <!-- Description -->
                <t t-if="property.description">
                    <div class="card border-0 shadow-sm mt-4">
                        <div class="card-header bg-transparent fw-bold border-bottom">
                            <i class="fa fa-align-left me-2 text-muted"/>Description
                        </div>
                        <div class="card-body">
                            <p class="mb-0 lh-lg"><span t-field="property.description"/></p>
                        </div>
                    </div>
                </t>

            </div>
        </t>
    </template>
</odoo>
