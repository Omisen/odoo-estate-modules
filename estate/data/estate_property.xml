<odoo>
    <data noupdate="1">
        
        <record id="estate_property_bigvilla" model="estate.property">
            <field name="name">Big Villa</field>
            <field name="status">new</field>
            <field name="postcode">12345</field>
            <field name="date_availability" eval="(datetime.now()-relativedelta(days=21)).strftime('%Y-%m-%d %H:%M:%S')"/>
            <field name="expected_price">1600000</field>
            <field name="bedrooms">6</field>
            <field name="living_area">100</field>
            <field name="garage" eval="True"/>
            <field name="garden" eval="True"/>
            <field name="garden_area">100000</field>
            <field name="garden_orientation">south</field>
            <field name="property_tag_id" eval="[Command.set([ref('estate.estate_property_tag_new_construction'), ref('estate_property_tag_luxury'), ref('estate_property_tag_sea_view')])]"/>
            <field name="property_type_id" ref="estate.estate_property_type_villa"/>
        </record>
        
        
        <record id="estate_property_trailerhome" model="estate.property">
            <field name="name">Trailer Home</field>
            <field name="status">cancelled</field>
            <field name="postcode">54321</field>
            <field name="date_availability" eval="(datetime.now()-relativedelta(days=21)).strftime('%Y-%m-%d %H:%M:%S')"/>
            <field name="expected_price">100000</field>
            <field name="bedrooms">1</field>
            <field name="living_area">10</field>
            <field name="garage" eval="False"/>
            <field name="property_tag_id" eval="[Command.set([ref('estate_property_tag_residential'), ref('estate_property_tag_renovated')])]"/>
            <field name="property_type_id" ref="estate.estate_property_type_residential"/>
        </record>

        
    </data>
</odoo>