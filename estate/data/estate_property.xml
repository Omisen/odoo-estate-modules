<odoo>
    <data noupdate="1">
        
        <record id="estate_property_bigvilla" model="estate.property">
            <field name="name">Big Villa</field>
            <field name="description">Prestigious luxury villa with 6 bedrooms, sprawling south-facing garden and private swimming pool. Fully equipped garage and breathtaking sea views. Ideal for high-end buyers seeking exclusivity and space.</field>
            <field name="status">offer_recieved</field>
            <field name="postcode">12345</field>
            <field name="date_availability" eval="(datetime.now()-relativedelta(days=21)).strftime('%Y-%m-%d %H:%M:%S')"/>
            <field name="expected_price">1600000</field>
            <field name="bedrooms">6</field>
            <field name="living_area">100</field>
            <field name="garage" eval="True"/>
            <field name="garden" eval="True"/>
            <field name="garden_area">100000</field>
            <field name="garden_orientation">south</field>
            <field name="property_tag_id" eval="[Command.set([ref('estate.estate_property_tag_new_construction'), ref('estate.estate_property_tag_luxury'), ref('estate.estate_property_tag_sea_view'), ref('estate.estate_property_tag_garden'), ref('estate.estate_property_tag_swimming_pool')])]"/>
            <field name="offer_ids" eval="[
                Command.create({'partner_id': ref('base.res_partner_12'), 'price': 1450000, 'validity': 7}),
                Command.create({'partner_id': ref('base.res_partner_10'), 'price': 1525000, 'validity': 10}),
            ]"/>
            <field name="property_type_id" ref="estate.estate_property_type_villa"/>
        </record>
        
        
        <record id="estate_property_trailerhome" model="estate.property">
            <field name="name">Trailer Home</field>
            <field name="description">Compact single-bedroom trailer home, ideal as a starter property or investment. Located in a quiet area and recently renovated. Suitable for budget-conscious buyers or seasonal use.</field>
            <field name="status">cancelled</field>
            <field name="postcode">54321</field>
            <field name="date_availability" eval="(datetime.now()-relativedelta(days=21)).strftime('%Y-%m-%d %H:%M:%S')"/>
            <field name="expected_price">100000</field>
            <field name="bedrooms">1</field>
            <field name="living_area">10</field>
            <field name="garage" eval="False"/>
            <field name="property_tag_id" eval="[Command.set([ref('estate.estate_property_tag_residential'), ref('estate.estate_property_tag_renovated'), ref('estate.estate_property_tag_quiet_area')])]"/>
            <field name="property_type_id" ref="estate.estate_property_type_trailerhome"/>
        </record>

        <record id="estate_property_cityloft" model="estate.property">
            <field name="name">City Loft</field>
            <field name="description">Modern 2-bedroom loft in the heart of the city. Smart home technology, private terrace and premium finishes throughout. Perfect for professionals or couples looking for urban living at its best.</field>
            <field name="status">offer_recieved</field>
            <field name="postcode">20100</field>
            <field name="date_availability" eval="(datetime.now()+relativedelta(days=15)).strftime('%Y-%m-%d %H:%M:%S')"/>
            <field name="expected_price">320000</field>
            <field name="bedrooms">2</field>
            <field name="living_area">85</field>
            <field name="garage" eval="False"/>
            <field name="garden" eval="False"/>
            <field name="property_tag_id" eval="[Command.set([ref('estate.estate_property_tag_residential'), ref('estate.estate_property_tag_central_location'), ref('estate.estate_property_tag_smart_home'), ref('estate.estate_property_tag_terrace')])]"/>
            <field name="offer_ids" eval="[
                Command.create({'partner_id': ref('base.res_partner_2'), 'price': 312000, 'validity': 11}),
                Command.create({'partner_id': ref('base.res_partner_12'), 'price': 315000, 'validity': 9}),
                Command.create({'partner_id': ref('base.res_partner_10'), 'price': 319000, 'validity': 4}),
                Command.create({'partner_id': ref('base.res_partner_1'), 'price': 320000, 'validity': 13}),
            ]"/>
            <field name="property_type_id" ref="estate.estate_property_type_appartament"/>
        </record>

        <record id="estate_property_greencottage" model="estate.property">
            <field name="name">Green Cottage</field>
            <field name="description">Charming 3-bedroom energy-efficient cottage with east-facing garden and private garage. Recently renovated and nestled in a peaceful countryside area. A perfect family home away from city noise.</field>
            <field name="status">new</field>
            <field name="postcode">33010</field>
            <field name="date_availability" eval="(datetime.now()+relativedelta(days=30)).strftime('%Y-%m-%d %H:%M:%S')"/>
            <field name="expected_price">245000</field>
            <field name="bedrooms">3</field>
            <field name="living_area">120</field>
            <field name="garage" eval="True"/>
            <field name="garden" eval="True"/>
            <field name="garden_area">250</field>
            <field name="garden_orientation">east</field>
            <field name="property_tag_id" eval="[Command.set([ref('estate.estate_property_tag_residential'), ref('estate.estate_property_tag_renovated'), ref('estate.estate_property_tag_garden'), ref('estate.estate_property_tag_quiet_area'), ref('estate.estate_property_tag_energy_efficient')])]"/>
            <field name="property_type_id" ref="estate.estate_property_type_cottage"/>
        </record>

        <record id="estate_property_oldwarehouse" model="estate.property">
            <field name="name">Old Warehouse</field>
            <field name="description">Spacious 200 sqm industrial warehouse with parking and garage. Partially renovated and ready for commercial use or conversion. Strong investment potential in a well-connected industrial zone.</field>
            <field name="status">cancelled</field>
            <field name="postcode">45000</field>
            <field name="date_availability" eval="(datetime.now()-relativedelta(days=10)).strftime('%Y-%m-%d %H:%M:%S')"/>
            <field name="expected_price">180000</field>
            <field name="bedrooms">0</field>
            <field name="living_area">200</field>
            <field name="garage" eval="True"/>
            <field name="garden" eval="False"/>
            <field name="property_tag_id" eval="[Command.set([ref('estate.estate_property_tag_commercial'), ref('estate.estate_property_tag_renovated'), ref('estate.estate_property_tag_investment'), ref('estate.estate_property_tag_parking')])]"/>
            <field name="property_type_id" ref="estate.estate_property_type_warehouse"/>
        </record>

    </data>
</odoo>