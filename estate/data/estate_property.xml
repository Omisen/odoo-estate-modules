<odoo>
    <data noupdate="1">
        
        <record id="estate_property_bigvilla" model="estate.property">
            <field name="name">Big Villa</field>
            <field name="status">new</field>
            <field name="postcode">12345</field>
            <field name="date_availability" eval="(datetime.now()-relativedelta(days=21)).strftime('%Y-%m-%d %H:%M:%S')"/>
            <field name="expected_price">1600000</field>
            <field name="bedrooms">6</field>
            <field name="living_area">100</field>
            <field name="garage" eval="True"/>
            <field name="garden" eval="True"/>
            <field name="garden_area">100000</field>
            <field name="garden_orientation">south</field>
            <field name="property_tag_id" eval="[Command.set([ref('estate.estate_property_tag_new_construction'), ref('estate_property_tag_luxury'), ref('estate_property_tag_sea_view')])]"/>
            <field name="property_type_id" ref="estate.estate_property_type_villa"/>
        </record>
        
        
        <record id="estate_property_trailerhome" model="estate.property">
            <field name="name">Trailer Home</field>
            <field name="status">cancelled</field>
            <field name="postcode">54321</field>
            <field name="date_availability" eval="(datetime.now()-relativedelta(days=21)).strftime('%Y-%m-%d %H:%M:%S')"/>
            <field name="expected_price">100000</field>
            <field name="bedrooms">1</field>
            <field name="living_area">10</field>
            <field name="garage" eval="False"/>
            <field name="property_tag_id" eval="[Command.set([ref('estate_property_tag_residential'), ref('estate_property_tag_renovated')])]"/>
            <field name="property_type_id" ref="estate.estate_property_type_residential"/>
        </record>

        <record id="estate_property_cityloft" model="estate.property">
            <field name="name">City Loft</field>
            <field name="status">new</field>
            <field name="postcode">20100</field>
            <field name="date_availability" eval="(datetime.now()+relativedelta(days=15)).strftime('%Y-%m-%d %H:%M:%S')"/>
            <field name="expected_price">320000</field>
            <field name="bedrooms">2</field>
            <field name="living_area">85</field>
            <field name="garage" eval="False"/>
            <field name="garden" eval="False"/>
            <field name="property_tag_id" eval="[Command.set([ref('estate_property_tag_residential')])]"/>
            <field name="property_type_id" ref="estate.estate_property_type_appartament"/>
        </record>

        <record id="estate_property_greencottage" model="estate.property">
            <field name="name">Green Cottage</field>
            <field name="status">new</field>
            <field name="postcode">33010</field>
            <field name="date_availability" eval="(datetime.now()+relativedelta(days=30)).strftime('%Y-%m-%d %H:%M:%S')"/>
            <field name="expected_price">245000</field>
            <field name="bedrooms">3</field>
            <field name="living_area">120</field>
            <field name="garage" eval="True"/>
            <field name="garden" eval="True"/>
            <field name="garden_area">250</field>
            <field name="garden_orientation">east</field>
            <field name="property_tag_id" eval="[Command.set([ref('estate_property_tag_residential'), ref('estate_property_tag_renovated')])]"/>
            <field name="property_type_id" ref="estate.estate_property_type_residential"/>
        </record>

        <record id="estate_property_oldwarehouse" model="estate.property">
            <field name="name">Old Warehouse</field>
            <field name="status">cancelled</field>
            <field name="postcode">45000</field>
            <field name="date_availability" eval="(datetime.now()-relativedelta(days=10)).strftime('%Y-%m-%d %H:%M:%S')"/>
            <field name="expected_price">180000</field>
            <field name="bedrooms">0</field>
            <field name="living_area">200</field>
            <field name="garage" eval="True"/>
            <field name="garden" eval="False"/>
            <field name="property_tag_id" eval="[Command.set([ref('estate_property_tag_renovated')])]"/>
            <field name="property_type_id" ref="estate.estate_property_type_industrial"/>
        </record>

    </data>
</odoo>